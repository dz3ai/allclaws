{
  "framework_version": "2.1.0",
  "encryption_enabled": true,
  "supported_platforms": [
    "openclaw",
    "clawteam",
    "goclaw",
    "ironclaw",
    "maxclaw",
    "nanoclaw",
    "nanobot",
    "zeroclaw",
    "hiclaw",
    "rtl-claw",
    "quantumclaw",
    "claw-ai-lab",
    "hermes-agent"
  ],
  "default_privilege_level": "standard",
  "audit_logging": true,
  "platform_paths": {
    "openclaw": "../openclaw",
    "clawteam": "../clawteam",
    "goclaw": "../goclaw",
    "ironclaw": "../ironclaw",
    "maxclaw": "../maxclaw",
    "nanoclaw": "../nanoclaw",
    "nanobot": "../nanobot",
    "zeroclaw": "../zeroclaw",
    "hiclaw": "./hiclaw",
    "rtl-claw": "./rtl-claw",
    "quantumclaw": "./quantumclaw",
    "claw-ai-lab": "./claw-ai-lab",
    "hermes-agent": "./hermes-agent"
  },
  "platform_languages": {
    "openclaw": "TypeScript",
    "clawteam": "Python",
    "goclaw": "Go",
    "ironclaw": "Rust",
    "maxclaw": "Go",
    "nanoclaw": "TypeScript",
    "nanobot": "Python",
    "zeroclaw": "Rust",
    "hiclaw": "Go",
    "rtl-claw": "Verilog",
    "quantumclaw": "TypeScript",
    "claw-ai-lab": "Python",
    "hermes-agent": "Python"
  },
  "test_categories": [
    "static_analysis",
    "codebase_metrics",
    "build_check",
    "security_audit",
    "documentation",
    "runtime_performance"
  ],
  "benchmark_metrics": {
    "repo_size": "Total repository size excluding build artifacts (KB)",
    "source_files": "Number of source files by language",
    "source_loc": "Total lines of code by language",
    "dependencies": "Number of declared dependencies",
    "test_files": "Number of test files (*_test.go, test_*.py, *.test.ts, etc.)",
    "ci_workflows": "Number of GitHub Actions workflow files",
    "ci_steps": "Total CI/CD steps across all workflows",
    "dockerfiles": "Number of Dockerfiles",
    "makefile_targets": "Number of Makefile targets",
    "readme_lines": "README file length (lines)",
    "docs_size": "Documentation directory size (KB)",
    "i18n_files": "Internationalization file count",
    "top_level_dirs": "Top-level directory count (complexity indicator)"
  },
  "runtime_benchmark_metrics": {
    "cold_start_time_ms": "Time from CLI invocation to first response (ms)",
    "memory_idle_mb": "Peak RSS of idle process (MB)",
    "memory_active_mb": "Peak RSS of active process with loaded modules (MB)",
    "response_latency_ms": "Time-to-first-token for echo benchmark (ms)",
    "token_efficiency_ratio": "Output tokens / input tokens ratio",
    "binary_size_kb": "Compiled binary size (KB)",
    "install_size_kb": "Installation footprint — node_modules/vendor/target/venv size (KB)",
    "build_proxy_time_ms": "Build check time as proxy for compilation (cargo check / go vet)",
    "mod_download_time_ms": "Dependency download time (go mod download / npm install dry-run)"
  }
}
